# ==================== FONCTIONS D'AIDE ====================
def set_cell_shading(cell, color_hex):
    """Applique une couleur de fond à une cellule"""
    shading = OxmlElement('w:shd')
    shading.set(qn('w:fill'), color_hex)
    cell._tc.get_or_add_tcPr().append(shading)

def add_heading(doc, text, level=1):
    """Ajoute un titre avec style personnalisé"""
    heading = doc.add_heading(text, level=level)
    return heading

def add_paragraph_with_numbering(doc, text, num_style='List Number'):
    """Ajoute un paragraphe numéroté"""
    p = doc.add_paragraph(text, style=num_style)
    return p

def add_table_from_data(doc, headers, rows, title=None):
    """Crée un tableau structuré"""
    if title:
        doc.add_paragraph(title, style='Heading 3')
    table = doc.add_table(rows=1+len(rows), cols=len(headers))
    table.style = 'Table Grid'
    table.autofit = False
    table.allow_autofit = True
    
    # En-têtes
    hdr_cells = table.rows[0].cells
    for i, header in enumerate(headers):
        hdr_cells[i].text = header
        set_cell_shading(hdr_cells[i], 'D9E2F3')
        for paragraph in hdr_cells[i].paragraphs:
            paragraph.runs[0].bold = True
    
    # Données
    for row_idx, row_data in enumerate(rows):
        row_cells = table.rows[row_idx + 1].cells
        for col_idx, cell_text in enumerate(row_data):
            row_cells[col_idx].text = str(cell_text)
    
    doc.add_paragraph()  # espace après tableau
    return table

